# Environment Variables for Enorve Marketing Site

# Google Analytics 4 Measurement ID
# Get your GA4 ID from https://analytics.google.com/
# Format: G-XXXXXXXXXX
# Leave empty to disable analytics
VITE_GA_MEASUREMENT_ID=

# Example:
# VITE_GA_MEASUREMENT_ID=G-1234567890

# Cloudflare Turnstile Site Key (waitlist bot protection)
# Get from https://dash.cloudflare.com/?to=/:account/turnstile
# Falls back to Turnstile test key if empty
VITE_TURNSTILE_SITE_KEY=
